{
  "name": "client",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "node ./scripts/dev-launcher.js",
    "dev:clear": "node ./scripts/dev-launcher.js --clear",
    "dev:expo": "expo start --dev-client -c",
    "dev:ios:sim": "node ./scripts/dev-launcher.js --target ios-sim --non-interactive",
    "dev:android:emu": "node ./scripts/dev-launcher.js --target android-emu --non-interactive",
    "dev:device": "node ./scripts/dev-launcher.js --target device --non-interactive",
    "dev:web": "node ./scripts/dev-launcher.js --target web --non-interactive",
    "dev:server": "node ./scripts/dev-launcher.js --target server --non-interactive",
    "dev:help": "node ./scripts/dev-launcher.js --help",
    "codex:web": "node ./scripts/codex-test-env.js web",
    "codex:test": "node ./scripts/codex-test-env.js playwright",
    "codex:test:smoke": "node ./scripts/codex-test-env.js playwright e2e/smoke.spec.js",
    "codex:test:real:category": "node ./scripts/codex-test-env.js playwright e2e/category-recovery.real.spec.js",
    "codex:test:real:todo": "node ./scripts/codex-test-env.js playwright e2e/todo-recovery.real.spec.js",
    "codex:test:real:completion": "node ./scripts/codex-test-env.js playwright e2e/completion-recovery.real.spec.js",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:device": "expo run:ios --device",
    "web": "expo start --web",
    "check-ip": "ipconfig getifaddr en0",
    "e2e:web": "playwright test",
    "e2e:web:headed": "playwright test --headed",
    "e2e:web:ui": "playwright test --ui",
    "e2e:web:install": "playwright install chromium"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/react-native-action-sheet": "^4.1.1",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "^8.4.4",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-menu/menu": "^1.2.3",
    "@react-navigation/bottom-tabs": "^7.9.0",
    "@react-navigation/native": "^7.1.26",
    "@react-oauth/google": "^0.13.0",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.90.12",
    "axios": "^1.13.2",
    "babel-plugin-module-resolver": "^5.0.2",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "expo": "^54.0.33",
    "expo-build-properties": "~1.0.10",
    "expo-crypto": "~15.0.8",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-router": "~6.0.23",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "i18next": "^25.7.3",
    "keen-slider": "^6.8.6",
    "nativewind": "^4.2.1",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "prop-types": "^15.8.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.5.0",
    "react-native": "0.81.5",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-ios-context-menu": "^3.2.0",
    "react-native-ios-utilities": "^5.2.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-toast-message": "^2.3.3",
    "react-native-web": "^0.21.0",
    "react-native-wheel-pick": "^1.2.6",
    "react-native-worklets": "0.5.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.19",
    "vaul": "^1.1.2",
    "zeego": "^3.0.6",
    "zustand": "^5.0.9"
  },
  "private": true,
  "overrides": {
    "react-native-safe-area-context": "~5.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@react-native-picker/picker": "2.11.1",
    "@types/react": "~19.1.10",
    "typescript": "^5.3.3"
  }
}
